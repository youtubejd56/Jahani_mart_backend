# Django Secret Key (generate a new one for production)
SECRET_KEY=your-secret-key-here

# Debug mode (set to False for production)
DEBUG=False

# Allowed hosts (comma-separated list of domains)
ALLOWED_HOSTS=your-backend.onrender.com

# CORS allowed origins (comma-separated list)
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# Neon PostgreSQL Database URL
DATABASE_URL=postgresql://neondb_owner:your-password@your-host.neon.tech/neondb?sslmode=require

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MSG91 OTP
MSG91_API_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
MSG91_OTP_MESSAGE=Your Jahani International password reset OTP is {otp}. It is valid for 10 minutes.
